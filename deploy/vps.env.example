# Copy to /var/www/aielegance/.env on the VPS (never commit real .env).
# Use plain ASCII quotes only. Same logical keys as local .env — see root .env.example.

# Public PocketBase URL (browser + SSR). Must match what you bake into the build:
#   NUXT_PUBLIC_POCKETBASE_URL=https://aielegance.com/pb npm run deploy
NUXT_PUBLIC_POCKETBASE_URL=https://aielegance.com/pb

# Node on the VPS talks to PocketBase here (PB listening on loopback behind nginx /pb).
POCKETBASE_INTERNAL_URL=http://127.0.0.1:8090

# Superuser for server-side collection access (same as PocketBase /_/ login).
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=change-me

# OpenRouter (required for script/LLM features).
OPENROUTER_API_KEY=sk-or-v1-replace-me

# Optional
# OPENROUTER_REFERER=https://aielegance.com
# OPENROUTER_TITLE=AI Elegance

# Nitro bind (optional; PM2/systemd often set these instead)
# HOST=0.0.0.0
# PORT=3000
