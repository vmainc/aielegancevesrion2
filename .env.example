# Copy to `.env` and fill in real values. `.env` is gitignored.

# PocketBase API (no trailing slash). Browsers use this URL.
NUXT_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090

# Optional: URL for Nuxt server only when PB is on localhost but public URL is proxied (e.g. /pb).
# POCKETBASE_INTERNAL_URL=http://127.0.0.1:8090

# PocketBase superuser (same as login at /_/) — required for saving questions, activity, ratings, etc.
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=change-me

# OpenRouter — required for /api/query/* and image generation
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-replace-me

# Optional OpenRouter attribution
# OPENROUTER_REFERER=https://your-domain.com
# OPENROUTER_TITLE=AI Elegance
